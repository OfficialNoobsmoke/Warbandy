root = true

[*.{js,ts,tsx,jsx,css,scss,md,json,html,d.ts}]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 2

[*.{yml,yaml}]
end_of_line = crlf
indent_style = space
indent_size = 2
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true